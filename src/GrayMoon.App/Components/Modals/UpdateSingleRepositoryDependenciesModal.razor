@using Microsoft.AspNetCore.Components.Web
@using GrayMoon.App.Models

@if (IsVisible && Payload != null)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);"
         @onkeydown="HandleKeyDown"
         @ref="_modalElement">
        <div class="modal-dialog modal-lg update-deps-modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Update dependencies</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="OnCancel"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2 small">
                        The following @(PackageLines.Count == 1 ? "dependency" : "dependencies") will be updated in <strong>@(RepoName ?? Payload.RepoName)</strong>:
                    </p>
                    <div class="update-deps-modal-packages-scroll small mb-3">
                        <ul class="list-unstyled mb-0 ps-0 update-deps-modal-packages">
                            @foreach (var line in PackageLines)
                            {
                                <li class="mb-1"><code>@line.PackageId</code> <span class="update-deps-modal-versions">@line.CurrentVersion <span class="update-deps-modal-arrow">→</span> @line.NewVersion</span></li>
                            }
                        </ul>
                    </div>
                    <p class="small text-muted mb-0">
                        .csproj files will be updated and committed.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-warning" @onclick="Proceed">
                        Proceed
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="OnCancel">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public SyncDependenciesRepoPayload? Payload { get; set; }
    [Parameter] public string? RepoName { get; set; }
    [Parameter] public EventCallback OnProceed { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private ElementReference _modalElement;

    private IReadOnlyList<(string PackageId, string CurrentVersion, string NewVersion)> PackageLines =>
        Payload?.ProjectUpdates
            .SelectMany(p => p.PackageUpdates)
            .GroupBy(x => (x.PackageId.Trim(), x.CurrentVersion.Trim(), x.NewVersion.Trim()))
            .Select(g => (g.Key.Item1, g.Key.Item2, g.Key.Item3))
            .ToList()
        ?? (IReadOnlyList<(string PackageId, string CurrentVersion, string NewVersion)>)Array.Empty<(string PackageId, string CurrentVersion, string NewVersion)>();

    private async Task Proceed()
    {
        await OnProceed.InvokeAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await OnCancel.InvokeAsync();
        }
        else if (e.Key == "Enter")
        {
            await Proceed();
        }
    }
}
