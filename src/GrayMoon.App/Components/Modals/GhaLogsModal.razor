@using GrayMoon.App.Repositories
@inject GitHubService GitHubService
@inject ConnectorRepository ConnectorRepository
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onkeydown="HandleKeyDown">
        <div class="modal-dialog modal-xl gha-logs-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(WorkflowDisplayName ?? "Workflow Logs")
                        <span class="text-muted fw-normal fs-6 ms-2">@RepositoryName</span>
                        @if (RunId > 0)
                        {
                            <span class="text-muted fw-normal fs-6 ms-2">#@RunId</span>
                        }
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseAsync"></button>
                </div>
                <div class="modal-body">
                    @if (_isLoading)
                    {
                        <div class="gha-logs-loading">
                            <span class="spinner-border text-secondary" role="status"></span>
                        </div>
                    }
                    else if (_errorMessage != null)
                    {
                        <div class="alert alert-danger m-3">@_errorMessage</div>
                    }
                    else if (_jobs.Count == 0)
                    {
                        <div class="alert alert-secondary m-3">No job logs available for this run.</div>
                    }
                    else
                    {
                        <div class="gha-logs-content" @ref="_contentRef">
                            @foreach (var job in _jobs)
                            {
                                <!-- Zero-height anchor: stable offsetTop relative to the scroll container -->
                                <div id="@($"gha-job-{job.Meta.Id}")" class="gha-job-anchor"></div>
                                <div class="gha-log-job">
                                    @foreach (var navJob in _jobs)
                                    {
                                        var isCurrent = navJob.Meta.Id == job.Meta.Id;
                                        var navJobAnchorId = $"gha-job-{navJob.Meta.Id}";
                                        <button type="button"
                                                class="gha-log-job__pill gha-log-job__pill--@(isCurrent ? JobStatusClass(navJob.Meta) : "other")"
                                                title="@navJob.Meta.Name"
                                                @onclick="() => ScrollToJobAsync(navJobAnchorId)">
                                            <span class="gha-log-job__icon-dot">@JobIcon(navJob.Meta)</span>
                                            <span class="gha-log-job__name">@navJob.Meta.Name</span>
                                        </button>
                                    }
                                </div>
                                @foreach (var entry in job.Entries)
                                {
                                    @if (entry is GhaLogGroupEntry group)
                                    {
                                        <details class="gha-log-group @(group.HasError ? "gha-log-group--error" : "")"
                                                 open>
                                            <summary class="gha-log-group__header">@((MarkupString)group.Title)</summary>
                                            <div class="gha-log-group__lines">
                                                @foreach (var line in group.Lines)
                                                {
                                                    <div class="gha-log-line gha-log-line--@KindClass(line.Kind)">@((MarkupString)line.HtmlContent)</div>
                                                }
                                            </div>
                                        </details>
                                    }
                                    else if (entry is GhaLogLineEntry topLine)
                                    {
                                        <div class="gha-log-line gha-log-line--@KindClass(topLine.Kind)">@((MarkupString)topLine.HtmlContent)</div>
                                    }
                                }
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <div>
                        <button type="button" class="btn btn-outline-secondary"
                                disabled="@(_jobs.Count == 0 || _isLoading)"
                                @onclick="DownloadLogsAsync">
                            Download
                        </button>
                    </div>
                    <div>
                        <button type="button" class="btn btn-outline-secondary" @onclick="CloseAsync">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string ConnectorName { get; set; } = string.Empty;
    [Parameter] public string Owner { get; set; } = string.Empty;
    [Parameter] public string RepositoryName { get; set; } = string.Empty;
    [Parameter] public long RunId { get; set; }
    [Parameter] public string? WorkflowDisplayName { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private record JobLogEntry(GitHubWorkflowJobDto Meta, List<GhaLogEntry> Entries, string? RawLog);

    private bool _wasVisible;
    private bool _isLoading;
    private bool _loadTriggered;
    private bool _autoSelectInitialized;
    private string? _errorMessage;
    private List<JobLogEntry> _jobs = [];
    private ElementReference _contentRef;

    protected override void OnParametersSet()
    {
        if (IsVisible && !_wasVisible)
        {
            _wasVisible = true;
            _isLoading = true;
            _loadTriggered = false;
            _autoSelectInitialized = false;
            _errorMessage = null;
            _jobs = [];
        }
        else if (!IsVisible)
        {
            _wasVisible = false;
            _loadTriggered = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isLoading && IsVisible && RunId > 0 && !_loadTriggered)
        {
            _loadTriggered = true;
            await LoadLogsAsync();
        }

        if (!_autoSelectInitialized && !_isLoading && _jobs.Count > 0)
        {
            _autoSelectInitialized = true;
            try { await JS.InvokeVoidAsync("ghaLogs.initAutoSelect", _contentRef); } catch { }
        }
    }

    private async Task LoadLogsAsync()
    {
        try
        {
            var connector = await ConnectorRepository.GetByNameAsync(ConnectorName);
            if (connector == null)
            {
                _errorMessage = $"Connector \"{ConnectorName}\" not found.";
                _isLoading = false;
                await InvokeAsync(StateHasChanged);
                return;
            }

            var jobsResponse = await GitHubService.GetWorkflowRunJobsAsync(connector, Owner, RepositoryName, RunId);
            var jobs = jobsResponse?.Jobs ?? [];

            var result = new List<JobLogEntry>();
            foreach (var job in jobs)
            {
                var rawLog = await GitHubService.GetJobLogsAsync(connector, Owner, RepositoryName, job.Id);
                var entries = rawLog != null
                    ? GhaLogParser.ParseJobLog(rawLog)
                    : [new GhaLogLineEntry(GhaLogLineKind.Normal, "Log not available.")];
                result.Add(new JobLogEntry(job, entries, rawLog));
            }

            _jobs = result;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ScrollToJobAsync(string anchorId)
    {
        try { await JS.InvokeVoidAsync("ghaLogs.scrollToJob", _contentRef, anchorId); } catch { }
    }

    private async Task DownloadLogsAsync()
    {
        var parts = _jobs.Select(j =>
            (_jobs.Count > 1 ? $"=== JOB: {j.Meta.Name} ===\n" : "") + (j.RawLog ?? "(no log available)"));
        var combined = string.Join("\n\n", parts);
        var filename = $"{(WorkflowDisplayName ?? "logs").Replace(' ', '-').Replace('/', '-')}-{RunId}.log";
        try { await JS.InvokeVoidAsync("ghaLogs.downloadText", filename, combined); } catch { }
    }

    private async Task CloseAsync() => await OnClose.InvokeAsync();

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await CloseAsync();
    }

    private static string KindClass(GhaLogLineKind kind) => kind switch
    {
        GhaLogLineKind.Error   => "error",
        GhaLogLineKind.Warning => "warning",
        GhaLogLineKind.Command => "command",
        GhaLogLineKind.Debug   => "debug",
        _                      => "normal",
    };

    private static string JobStatusClass(GitHubWorkflowJobDto job) =>
        job.Conclusion?.ToLowerInvariant() switch
        {
            "success"   => "success",
            "failure"   => "failure",
            "cancelled" => "aborted",
            "skipped"   => "skipped",
            _ => string.Equals(job.Status, "in_progress", StringComparison.OrdinalIgnoreCase) ? "running" : "none",
        };

    private static string JobIcon(GitHubWorkflowJobDto job)
    {
        if (string.Equals(job.Status, "completed", StringComparison.OrdinalIgnoreCase))
        {
            return job.Conclusion?.ToLowerInvariant() switch
            {
                "success"   => "✓",
                "failure"   => "✗",
                "cancelled" => "✗",
                "skipped"   => "↩",
                _           => "·",
            };
        }
        if (string.Equals(job.Status, "in_progress", StringComparison.OrdinalIgnoreCase)) return "▶";
        return "○";
    }
}
