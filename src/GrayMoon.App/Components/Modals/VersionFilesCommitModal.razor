@using Microsoft.AspNetCore.Components.Web

@if (IsVisible)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);"
         @onkeydown="HandleKeyDown">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Commit version files</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="OnCancel"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(Message))
                    {
                        <p class="mb-2">@Message</p>
                    }
                    @if (Files != null && Files.Count > 0)
                    {
                        <div class="version-files-commit-label mb-1">Files</div>
                        <div class="version-files-commit-box">
                            <pre class="version-files-commit-pre mb-0 font-monospace p-2">
@string.Join("\n", Files)
                            </pre>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" @onclick="OnProceed" disabled="@IsBusy">
                        Commit
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="OnCancel" disabled="@IsBusy">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string? Message { get; set; }
    [Parameter] public IReadOnlyList<string>? Files { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public EventCallback OnProceed { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            await OnCancel.InvokeAsync();
        else if (e.Key == "Enter")
            await OnProceed.InvokeAsync();
    }
}

