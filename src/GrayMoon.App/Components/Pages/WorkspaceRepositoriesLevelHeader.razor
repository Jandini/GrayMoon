@using GrayMoon.App.Models
@using GrayMoon.App.Services
@using Microsoft.AspNetCore.Components.Web

<tr class="dependency-level-header">
    <td colspan="@ColSpan" class="dependency-level-header-cell">
        <div class="dependency-level-header-start">
            <span class="dependency-level-title @(LevelKey == null ? "dependency-level-no-projects" : "")">@(LevelKey == null ? "No dependencies" : $"Level {LevelKey}")</span>
            @if (LevelKey.HasValue)
            {
                <a href="@WorkspaceUrlHelper.GetDependencyGraphUrl(WorkspaceId, level: LevelKey!.Value)" class="dependency-level-graph-link" title="View dependency graph for this level" aria-label="Dependency graph">
                    <i class="bi bi-diagram-3" aria-hidden="true"></i>
                </a>
            }
        </div>
        <div class="dependency-level-header-end">
            <span class="dependency-level-icons @(ActionsDisabled ? "dependency-level-icons--disabled" : "")">
                <span class="dependency-level-sync-to-default-link"
                      role="button"
                      tabindex="@(ActionsDisabled ? -1 : 0)"
                      title="Sync to default branch..."
                      style="cursor: @(ActionsDisabled ? "not-allowed" : "pointer");"
                      @onclick="HandleSyncToDefault"
                      @onclick:preventDefault
                      aria-label="Sync to default branch"
                      aria-disabled="@ActionsDisabled">
                    <i class="bi bi-rewind" aria-hidden="true"></i>
                </span>
                <span class="dependency-level-sync-commits-link"
                      role="button"
                      tabindex="@(ActionsDisabled ? -1 : 0)"
                      title="Sync commits for all repositories in this level"
                      style="cursor: @(ActionsDisabled ? "not-allowed" : "pointer");"
                      @onclick="HandleSyncCommits"
                      @onclick:preventDefault
                      aria-label="Sync commits"
                      aria-disabled="@ActionsDisabled">
                    <i class="bi bi-arrow-down-up" aria-hidden="true"></i>
                </span>
                <span class="dependency-level-pr-link"
                      role="button"
                      tabindex="@(ActionsDisabled ? -1 : 0)"
                      title="Open Pull Request in GitHub..."
                      style="cursor: @(ActionsDisabled ? "not-allowed" : "pointer");"
                      @onclick="HandleOpenPr"
                      @onclick:preventDefault
                      @onclick:stopPropagation
                      aria-label="Open Pull Request"
                      aria-disabled="@ActionsDisabled">
                    <i class="bi bi-git" aria-hidden="true"></i>
                </span>
                <span class="dependency-level-sync-link"
                      role="button"
                      tabindex="@(ActionsDisabled ? -1 : 0)"
                      title="Synchronize all repositories in this level..."
                      style="cursor: @(ActionsDisabled ? "not-allowed" : "pointer");"
                      @onclick="HandleSyncLevel"
                      @onclick:preventDefault
                      aria-label="Sync level"
                      aria-disabled="@ActionsDisabled">
                    <i class="bi bi-arrow-repeat" aria-hidden="true"></i>
                </span>
            </span>
            <span class="dependency-level-count dependency-level-count-link"
                  role="button"
                  tabindex="0"
                  title="Open in GitHub..."
                  style="cursor: pointer;"
                  @onclick="HandleOpenGitHubClick"
                  @onclick:preventDefault
                  @onclick:stopPropagation>
                <span class="dependency-level-count-num">@RepositoryCount</span> @(RepositoryCount == 1 ? "repository" : "repositories")
            </span>
        </div>
    </td>
</tr>

@code {
    [Parameter] public int WorkspaceId { get; set; }
    [Parameter] public int? LevelKey { get; set; }
    [Parameter] public int ColSpan { get; set; } = 8;
    [Parameter] public IEnumerable<WorkspaceRepositoryLink>? Group { get; set; }
    [Parameter] public bool ActionsDisabled { get; set; }
    [Parameter] public EventCallback OnSyncToDefault { get; set; }
    [Parameter] public EventCallback OnSyncCommits { get; set; }
    [Parameter] public EventCallback OnOpenPr { get; set; }
    [Parameter] public EventCallback OnSyncLevel { get; set; }
    [Parameter] public EventCallback<(int count, IReadOnlyList<string?> urls)> OnOpenGitHub { get; set; }

    private int RepositoryCount => Group?.Count() ?? 0;

    private async Task HandleSyncToDefault()
    {
        if (!ActionsDisabled) await OnSyncToDefault.InvokeAsync();
    }

    private async Task HandleSyncCommits()
    {
        if (!ActionsDisabled) await OnSyncCommits.InvokeAsync();
    }

    private async Task HandleOpenPr()
    {
        if (!ActionsDisabled) await OnOpenPr.InvokeAsync();
    }

    private async Task HandleSyncLevel()
    {
        if (!ActionsDisabled) await OnSyncLevel.InvokeAsync();
    }

    private async Task HandleOpenGitHubClick()
    {
        if (Group == null) return;
        var urls = Group
            .Select(wr => wr.Repository)
            .Where(r => r != null)
            .Select(r => RepositoryUrlHelper.GetRepositoryUrl(r!.CloneUrl))
            .ToList();
        await OnOpenGitHub.InvokeAsync((RepositoryCount, urls));
    }
}
