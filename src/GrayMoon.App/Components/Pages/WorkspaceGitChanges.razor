@page "/workspaces/{WorkspaceId:int}/changes"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using GrayMoon.App.Components.GitChanges
@using GrayMoon.App.Components.Shared
@using GrayMoon.App.Services.GitChanges
@using GrayMoon.Common.Git

<PageTitle>Changes - GrayMoon</PageTitle>

<div class="container-fluid page-container grid-page git-changes-page">
    <div class="grid-page-header">
        <GitChangesHeader View="_view" StatusText="@(_isWarmingUp ? _warmUpStatus : null)" />
    </div>

    <div class="grid-page-body">
    @if (_errorMessage != null)
    {
        <div class="alert alert-danger">@_errorMessage</div>
    }
    else if (_isLoading && _view == null)
    {
        <div class="git-changes-empty text-muted">Loading Changes…</div>
    }
    else if (_view != null && _view.Repositories.Count == 0)
    {
        <div class="git-changes-empty text-muted">
            No changes
        </div>
    }
    else
    {
        <div class="graymoon-splitter git-changes-splitter" id="git-changes-splitter">
            <div class="graymoon-splitter__left git-changes-splitter__left">
                @if (ChangedRepositoryCount > 0)
                {
                    <div class="git-changes-workspace-commit">
                        <form autocomplete="off" @onsubmit:preventDefault="true">
                        <textarea id="git-changes-commit-message"
                                  class="form-control git-changes-workspace-commit__message"
                                  rows="3"
                                  maxlength="10000"
                                  placeholder="Commit message (applies to all repositories below)"
                                  autocomplete="off"
                                  autocorrect="off"
                                  autocapitalize="off"
                                  spellcheck="false"
                                  value="@_workspaceCommitMessage"
                                  @oninput="OnWorkspaceCommitMessageInput"></textarea>
                        </form>
                        <div class="git-changes-workspace-commit__actions">
                            @if (StagedRepositoryCount > 0)
                            {
                                <button type="button"
                                        class="btn btn-sm btn-primary"
                                        disabled="@(IsJobRunning || string.IsNullOrWhiteSpace(_workspaceCommitMessage))"
                                        title="Creates one commit in each staged repository using the same message."
                                        @onclick="() => CommitWorkspaceAsync(stagedOnly: true)">
                                    Commit Staged
                                </button>
                            }
                            else
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-primary"
                                        disabled="@(IsJobRunning || string.IsNullOrWhiteSpace(_workspaceCommitMessage))"
                                        title="Stages all changes then creates one commit in each repository using the same message."
                                        @onclick="() => CommitWorkspaceAsync(stagedOnly: false)">
                                    Commit All
                                </button>
                            }
                        </div>
                    </div>
                }

                <GitChangesTree Rows="_rows"
                                 OfflineNotice="@OfflineNotice"
                                 IsFilterActive="@(!string.IsNullOrWhiteSpace(_filterQuery))"
                                 HasChanges="@(ChangedRepositoryCount > 0)"
                                 SelectedRow="_selectedRow"
                                 OnToggleExpand="ToggleExpanded"
                                 OnSelectFile="SelectFile"
                                 OnStage="args => StageAsync(args.WorkspaceRepositoryId, args.Scope, args.Paths)"
                                 OnUnstage="args => UnstageAsync(args.WorkspaceRepositoryId, args.Scope, args.Paths)"
                                 IsMutating="IsMutating"
                                 OnStageAllChanged="StageAllChangedAsync"
                                 OnUnstageAllStaged="UnstageAllStagedAsync" />
            </div>

            <div class="graymoon-splitter__handle git-changes-splitter__handle" aria-hidden="true"></div>

            <div class="graymoon-splitter__right git-changes-splitter__right">
                @if (_selectedRow is not { Kind: GitChangesTreeRowKind.File })
                {
                    <div class="git-changes-diff-placeholder text-muted">
                        <div>Select a file to view its diff</div>
                    </div>
                }
                else
                {
                    @if (_isDiffLoading)
                    {
                        <div class="git-changes-diff-placeholder text-muted">Loading diff…</div>
                    }
                    else if (_diffError != null)
                    {
                        <div class="alert alert-danger m-2">@_diffError</div>
                    }
                    else if (_selectedDiff != null && !RendersInMonaco(_selectedDiff.State))
                    {
                        <div class="git-changes-diff-placeholder text-muted">
                            @switch (_selectedDiff.State)
                            {
                                case GitDiffContentState.Binary:
                                    <div>
                                        Binary file changed.
                                        @if (_selectedDiff.OriginalSizeBytes != null || _selectedDiff.ModifiedSizeBytes != null)
                                        {
                                            <div>@(_selectedDiff.OriginalSizeBytes ?? 0) bytes &rarr; @(_selectedDiff.ModifiedSizeBytes ?? 0) bytes</div>
                                        }
                                    </div>
                                    break;
                                case GitDiffContentState.TooLarge:
                                    <div>File is too large to diff automatically.</div>
                                    break;
                                case GitDiffContentState.UnsupportedEncoding:
                                    <div>File encoding is not supported for preview.</div>
                                    break;
                                default:
                                    <div>@(_diffError ?? "Unable to display this diff.")</div>
                                    break;
                            }
                        </div>
                    }

                    <div class="git-diff-viewer-container" style="display:@((_selectedDiff != null && RendersInMonaco(_selectedDiff.State)) ? "flex" : "none")">
                        <GitDiffViewer @ref="_diffViewerRef"
                                       FileName="@System.IO.Path.GetFileName(_selectedRow.FilePath)"
                                       OriginalSideLabel="@(_selectedRow.IsStagedSection ? "(HEAD)" : "(Index)")"
                                       ModifiedSideLabel="@(_selectedRow.IsStagedSection ? "(Index)" : "(Working Tree)")" />
                    </div>
                }

                <div class="git-diff-toolbar">
                    <div class="git-diff-toolbar__filter">
                        <FilterSearchInput Value="@_filterQuery"
                                           ValueChanged="OnFilterChanged"
                                           InputId="git-changes-filter"
                                           InputAdditionalClass="git-diff-toolbar__filter-input"
                                           WrapperAdditionalClass="git-diff-toolbar__filter-wrap"
                                           EnableSyntaxHighlight="false"
                                           Placeholder="Filter by repo, path, status..."
                                           Disabled="@_isLoading" />
                    </div>
                    <div class="git-diff-toolbar__actions">
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                title="Refresh - rescans every repository in this workspace"
                                aria-label="Refresh"
                                disabled="@(_isLoading || IsJobRunning)"
                                @onclick="ManualRefreshAsync">
                            <i class="bi bi-arrow-clockwise" aria-hidden="true"></i>
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                title="Previous change"
                                disabled="@(_selectedDiff == null || !RendersInMonaco(_selectedDiff.State))"
                                @onclick="() => _diffViewerRef!.GoToPreviousChangeAsync()">
                            <i class="bi bi-chevron-up" aria-hidden="true"></i>
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                title="Next change"
                                disabled="@(_selectedDiff == null || !RendersInMonaco(_selectedDiff.State))"
                                @onclick="() => _diffViewerRef!.GoToNextChangeAsync()">
                            <i class="bi bi-chevron-down" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    </div>
</div>
