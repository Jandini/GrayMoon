@page "/workspaces/{WorkspaceId:int}/files"
@rendermode InteractiveServer
@using GrayMoon.App.Components.Shared
@using GrayMoon.App.Models
@using GrayMoon.App.Models.Api
@using GrayMoon.App.Repositories
@using GrayMoon.App.Services
@using GrayMoon.App.Components.Modals
@using GrayMoon.App.Api.Endpoints
@using Microsoft.AspNetCore.Components.Web
@inject WorkspaceRepository WorkspaceRepository
@inject WorkspaceFileRepository WorkspaceFileRepository
@inject WorkspaceFileVersionConfigRepository VersionConfigRepository
@inject WorkspaceFileVersionService FileVersionService
@inject WorkspaceService WorkspaceService
@inject IToastService ToastService
@inject ILogger<WorkspaceFiles> Logger
@using WorkspaceModel = GrayMoon.App.Models.Workspace

<PageTitle>Files - GrayMoon</PageTitle>

<div class="container-fluid page-container grid-page">
    <div class="grid-page-header">
        <div class="workspace-repos-header workspace-files-header">
            <div class="workspace-repos-title-row">
                <h2 class="workspace-repos-title">Files</h2>
                <p class="text-muted mb-0 workspace-repos-subtitle workspace-files__subtitle">
                    @if (!isLoading && files.Count > 0)
                    {
                        var fileSuffix = HasSearchFilter ? " found" : "";
                        var fileCount = HasSearchFilter ? FilteredFileCount : files.Count;
                        <span>@($"{fileCount} {(fileCount == 1 ? "file" : "files")}{fileSuffix}")</span>
                    }
                    else if (!isLoading && workspace != null)
                    {
                        <span>0 files</span>
                    }
                    else if (isLoading)
                    {
                        <span>&nbsp;</span>
                    }
                </p>
                <span class="workspace-repos-title-spacer"></span>
            </div>
            <div class="d-flex gap-2 align-items-center workspace-repos-header-actions">
                <div class="workspace-repos-search-wrapper">
                    <div class="workspace-repos-search-input-wrap @(HasSearchFilter ? "has-filter" : null)">
                        <input id="workspace-files-search"
                               class="form-control workspace-repos-search"
                               placeholder="Search file name, path, or repository..."
                               value="@searchTerm"
                               disabled="@(isLoading || files.Count == 0)"
                               @oninput="OnSearchChanged"
                               @onkeydown="OnSearchKeyDown" />
                        @if (HasSearchFilter)
                        {
                            <button type="button"
                                    class="workspace-repos-search-clear"
                                    title="Clear filter"
                                    aria-label="Clear search filter"
                                    @onclick="ClearSearchFilter"
                                    @onclick:stopPropagation="true">
                                <i class="bi bi-x-circle" aria-hidden="true"></i>
                            </button>
                        }
                    </div>
                </div>
                <button class="btn btn-outline-primary" @onclick="UpdateVersionsAsync"
                        disabled="@(fileVersionConfigs.Count == 0)" title="Update versions in all configured files">
                    Update
                </button>
                <button class="btn btn-primary" @onclick="OpenAddFilesModal">
                    Add Files
                </button>
            </div>
        </div>
        @if (errorMessage != null)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle"></i> @errorMessage
            </div>
        }
    </div>
    @if (errorMessage == null)
    {
        <div class="grid-page-body">
            <div class="card page-card mb-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 workspaces-table resizable-columns">
                            <thead class="table-dark">
                                <tr>
                                    <th class="col-filename text-nowrap">File Name</th>
                                    <th class="col-filepath text-nowrap">File Path</th>
                                    <th class="col-repo text-nowrap">Repository</th>
                                    <th class="col-actions text-nowrap">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (isLoading)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">Loading files...</td>
                                    </tr>
                                }
                                else if (files.Count == 0)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">
                                            No files in this workspace. Use "Add Files" to search and add files from your repositories.
                                        </td>
                                    </tr>
                                }
                                else if (NoFilesMatchSearch)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">
                                            No files match your search.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var f in FilteredFiles)
                                    {
                                        <tr>
                                            <td class="col-filename"><strong>@f.FileName</strong></td>
                                            <td class="col-filepath text-muted">@f.FilePath</td>
                                            <td class="col-repo">@(f.RepositoryName ?? "-")</td>
                                            <td class="col-actions">
                                                <button class="btn btn-sm btn-outline-secondary me-2"
                                                        @onclick="() => OpenViewFileModal(f)"
                                                        title="View file contents">
                                                    View
                                                </button>
                                                <button class="btn btn-sm me-2 @(fileVersionConfigs.ContainsKey(f.FileId) ? "btn-info" : "btn-outline-secondary")"
                                                        @onclick="() => OpenVersionConfigModal(f)"
                                                        title="@(fileVersionConfigs.ContainsKey(f.FileId) ? "Edit version configuration" : "Configure versioning")">
                                                    Configure
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger"
                                                        @onclick="() => RemoveFileAsync(f)"
                                                        title="Remove file">
                                                    Remove
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<AddFilesModal IsVisible="@showFileModal"
                WorkspaceId="WorkspaceId"
                WorkspaceRepos="@workspaceRepos"
                OnAdd="OnFilesAdded"
                OnCancel="CloseAddFilesModal" />

<VersionConfigModal IsVisible="@showVersionConfigModal"
                    File="@configuringFile"
                    WorkspaceRepos="@workspaceRepos"
                    CurrentPattern="@currentConfigPattern"
                    OnSaved="OnVersionPatternSaved"
                    OnCancel="CloseVersionConfigModal" />

<ViewFileModal IsVisible="@showViewFileModal"
               File="@(viewingFile!)"
               WorkspaceName="@(workspace?.Name)"
               WorkspaceRoot="@workspaceRoot"
               IsConfigured="@(viewingFile != null && fileVersionConfigs.ContainsKey(viewingFile.FileId))"
               OnClose="CloseViewFileModal"
               OnConfigure="OnConfigureFromView" />

<LoadingOverlay IsVisible="@isUpdating" Message="@updateMessage" OnAbort="AbortUpdate" />

@code {
    [Parameter] public int WorkspaceId { get; set; }

    private WorkspaceModel? workspace;
    private List<WorkspaceFileDto> files = new();
    private List<WorkspaceRepoItem> workspaceRepos = new();
    private Dictionary<int, string> fileVersionConfigs = new();
    private string? errorMessage;
    private bool isLoading = true;
    private bool showFileModal;
    private bool showVersionConfigModal;
    private WorkspaceFileDto? configuringFile;
    private string? currentConfigPattern;
    private bool showViewFileModal;
    private WorkspaceFileDto? viewingFile;
    private string? workspaceRoot;
    private bool isUpdating;
    private string updateMessage = "";
    private CancellationTokenSource? _updateCts;
    private string searchTerm = string.Empty;

    private bool HasSearchFilter => !string.IsNullOrWhiteSpace(searchTerm);

    private IReadOnlyList<WorkspaceFileDto> FilteredFiles => GetFilteredFiles();

    private int FilteredFileCount => FilteredFiles.Count;

    private bool NoFilesMatchSearch =>
        !isLoading && files.Count > 0 && FilteredFiles.Count == 0;

    private IReadOnlyList<WorkspaceFileDto> GetFilteredFiles()
    {
        var words = SplitSearchWords(searchTerm);
        if (words.Count == 0)
            return files;
        return files.Where(f =>
        {
            var name = f.FileName ?? string.Empty;
            var path = f.FilePath ?? string.Empty;
            var repo = f.RepositoryName ?? string.Empty;
            var haystack = $"{name} {path} {repo}";
            return words.All(w => haystack.Contains(w, StringComparison.OrdinalIgnoreCase));
        }).ToList();
    }

    private static List<string> SplitSearchWords(string term) =>
        term
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(w => w.Trim())
            .Where(w => w.Length > 0)
            .ToList();

    private void OnSearchChanged(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        StateHasChanged();
    }

    private void ClearSearchFilter()
    {
        searchTerm = string.Empty;
        StateHasChanged();
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            searchTerm = string.Empty;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            workspace = await WorkspaceRepository.GetByIdAsync(WorkspaceId);
            if (workspace == null)
            {
                errorMessage = "Workspace not found.";
                files = new List<WorkspaceFileDto>();
                workspaceRepos = new List<WorkspaceRepoItem>();
                workspaceRoot = null;
                return;
            }
            workspaceRoot = await WorkspaceService.GetRootPathForWorkspaceAsync(workspace, default);
            workspaceRepos = workspace.Repositories
                .Where(r => r.Repository != null)
                .Select(r => new WorkspaceRepoItem { RepositoryId = r.RepositoryId, RepositoryName = r.Repository!.RepositoryName })
                .ToList();
            var list = await WorkspaceFileRepository.GetByWorkspaceIdAsync(WorkspaceId);
            files = list.Select(f => new WorkspaceFileDto
            {
                FileId = f.FileId,
                WorkspaceId = f.WorkspaceId,
                RepositoryId = f.RepositoryId,
                RepositoryName = f.Repository?.RepositoryName,
                FileName = f.FileName,
                FilePath = f.FilePath
            }).ToList();
            var configs = await VersionConfigRepository.GetByWorkspaceIdAsync(WorkspaceId);
            fileVersionConfigs = configs.ToDictionary(c => c.FileId, c => c.VersionPattern);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading files for workspace {WorkspaceId}", WorkspaceId);
            errorMessage = "Failed to load files. Please try again later.";
            files = new List<WorkspaceFileDto>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenAddFilesModal()
    {
        showFileModal = true;
    }

    private void CloseAddFilesModal()
    {
        showFileModal = false;
    }

    private void OpenVersionConfigModal(WorkspaceFileDto f)
    {
        configuringFile = f;
        currentConfigPattern = fileVersionConfigs.TryGetValue(f.FileId, out var p) ? p : null;
        showVersionConfigModal = true;
    }

    private void OpenViewFileModal(WorkspaceFileDto f)
    {
        viewingFile = f;
        showViewFileModal = true;
    }

    private void CloseViewFileModal()
    {
        showViewFileModal = false;
        viewingFile = null;
    }

    private void OnConfigureFromView(string? selectedText)
    {
        if (viewingFile == null) return;
        configuringFile = viewingFile;
        currentConfigPattern = selectedText;
        showViewFileModal = false;
        showVersionConfigModal = true;
    }

    private void CloseVersionConfigModal()
    {
        showVersionConfigModal = false;
        configuringFile = null;
        currentConfigPattern = null;
    }

    private async Task OnVersionPatternSaved(string pattern)
    {
        if (configuringFile == null) return;
        try
        {
            if (string.IsNullOrWhiteSpace(pattern))
            {
                await VersionConfigRepository.DeleteByFileIdAsync(configuringFile.FileId);
                fileVersionConfigs.Remove(configuringFile.FileId);
            }
            else
            {
                var normalized = WorkspaceFileVersionService.NormalizePatternLeadingWhitespace(pattern);
                await VersionConfigRepository.UpsertAsync(configuringFile.FileId, normalized);
                fileVersionConfigs[configuringFile.FileId] = normalized;
            }
            CloseVersionConfigModal();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving version config for FileId={FileId}", configuringFile.FileId);
            errorMessage = "Failed to save version configuration.";
        }
    }

    private async Task UpdateVersionsAsync()
    {
        _updateCts?.Cancel();
        _updateCts?.Dispose();
        _updateCts = new CancellationTokenSource();
        isUpdating = true;
        errorMessage = null;
        updateMessage = "Updating file versions...";
        StateHasChanged();
        try
        {
            var (updated, failed, error, _) = await FileVersionService.UpdateAllVersionsAsync(WorkspaceId, selectedRepositoryIds: null, cancellationToken: _updateCts.Token);
            if (error != null)
                errorMessage = error;
            else if (failed > 0)
                errorMessage = $"Updated {updated} line(s). {failed} file(s) could not be updated - check logs.";
            else
                ToastService.Show("Versions updated in configured files.");
        }
        catch (OperationCanceledException) { /* user aborted */ }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating versions for WorkspaceId={WorkspaceId}", WorkspaceId);
            errorMessage = "Failed to update versions. Please try again.";
        }
        finally
        {
            isUpdating = false;
            StateHasChanged();
        }
    }

    private void AbortUpdate() => _updateCts?.Cancel();

    private async Task RemoveFileAsync(WorkspaceFileDto f)
    {
        try
        {
            errorMessage = null;
            await WorkspaceFileRepository.RemoveAsync(f.FileId);
            files.Remove(f);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error removing workspace file {FileId}", f.FileId);
            errorMessage = "Failed to remove file. Please try again.";
        }
    }

    private async Task OnFilesAdded(List<WorkspaceFileAddItem> items)
    {
        if (items.Count == 0) { CloseAddFilesModal(); return; }
        try
        {
            var toAdd = items.Select(i => (i.RepositoryId, i.FileName, i.FilePath)).ToList();
            await WorkspaceFileRepository.AddRangeAsync(WorkspaceId, toAdd);
            CloseAddFilesModal();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error adding workspace files");
            errorMessage = "Failed to add files. Please try again.";
        }
    }
}
