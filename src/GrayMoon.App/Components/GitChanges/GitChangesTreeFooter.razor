@namespace GrayMoon.App.Components.GitChanges
@using GrayMoon.App.Components.Shared
@using GrayMoon.App.Services.GitChanges

<div class="git-changes-tree-footer">
    <div class="workspace-grid-search-wrapper git-changes-tree-footer__search">
        <FilterSearchInput Value="@FilterQuery"
                           ValueChanged="OnFilterValueChanged"
                           InputId="git-changes-filter"
                           InputAdditionalClass="workspace-grid-search"
                           Placeholder="Filter by repo, path, status..."
                           Disabled="@(IsLoading || !HasChanges)" />
    </div>
    <button type="button"
            class="btn btn-outline-secondary git-changes-tree-footer__refresh"
            @onclick="OnRefreshClick"
            disabled="@IsLoading">
        @if (IsLoading)
        {
            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
        }
        Refresh
    </button>
</div>

@code {
    [Parameter] public WorkspaceGitChangesView? View { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public string FilterQuery { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> FilterQueryChanged { get; set; }

    private bool HasChanges => View is { Repositories.Count: > 0 };

    private Task OnRefreshClick() => OnRefresh.InvokeAsync();

    private Task OnFilterValueChanged(string value) => FilterQueryChanged.InvokeAsync(value);
}
