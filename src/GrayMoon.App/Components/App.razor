<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="bootstrap-icons/bootstrap-icons.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="css/loading-overlay.css" />
    <link rel="stylesheet" href="GrayMoon.App.styles.css" />
    <link rel="icon" type="image/svg+xml" href="moon.svg" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script src="js/cytoscape.min.js"></script>
    <script src="js/dagre.min.js"></script>
    <script src="js/cytoscape-dagre.js"></script>
    <script src="js/cytoscape-graph.js"></script>
    <script src="js/resizable-columns.js"></script>
    <script src="js/matrixOverlay.js"></script>
    <script src="js/versionPatternEditor.js"></script>
    <script src="js/fileViewer.js"></script>
    <script>
        window.focusFirstModalInput = (id) => {
            const el = document.getElementById(id);
            if (el) {
                const input = el.querySelector('input:not([type=hidden]):not([disabled]), textarea:not([disabled])');
                if (input) input.focus();
            }
        };
        window.focusElement = (id) => {
            const el = document.getElementById(id);
            if (el) el.focus();
        };
        window.scrollElementIntoView = (element) => {
            if (element && element.scrollIntoView)
                element.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        };
        window.getAgentDownloadInfo = () => {
            const ua = navigator.userAgent.toLowerCase();
            const platform = (navigator.platform || '').toLowerCase();
            const isWindows = /win(dows|32|64|ce)/.test(ua) || platform.indexOf('win') === 0;
            const qs = isWindows ? '?platform=windows' : '';
            const filename = isWindows ? 'graymoon-agent.exe' : 'graymoon-agent';
            const base = (document.querySelector('base')?.getAttribute('href') || '/').replace(/\/$/, '') || '';
            const path = base + '/api/agent/download' + qs;
            const url = path.startsWith('http') ? path : (window.location.origin + path);
            return { url, filename };
        };
        window.graymoonDownloadAgent = () => {
            const { url, filename } = window.getAgentDownloadInfo();
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            a.rel = 'noopener';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        };
        window.graymoonOpenUrls = (urls) => {
            if (Array.isArray(urls))
                urls.forEach(url => window.open(url, '_blank', 'noopener,noreferrer'));
        };
        // GitHub dropdown: body-appended, fixed-position overlay driven by mouse delegation.
        // Avoids table-responsive overflow clipping. Reads data-urls JSON from the trigger.
        (function () {
            const ITEMS = [
                { label: 'Branches',      icon: 'bi-signpost-2',         suffix: '/branches' },
                { label: 'Pull Requests', icon: 'bi-git',                suffix: '/pulls'    },
                { label: 'Actions',       icon: 'bi-play-circle',        suffix: '/actions'  },
                { label: 'Releases',      icon: 'bi-box-seam',           suffix: '/releases' },
                { label: 'Tags',          icon: 'bi-tag',                suffix: '/tags'     },
                { label: 'Issues',        icon: 'bi-exclamation-circle', suffix: '/issues'   },
                { label: 'Settings',      icon: 'bi-gear',               suffix: '/settings' },
            ];
            let panel = null, hideTimer = null, activeTrigger = null;

            function build() {
                panel = document.createElement('div');
                panel.className = 'gm-gh-dropdown';
                const title = document.createElement('div');
                title.className = 'gm-gh-dropdown-title';
                title.textContent = 'Open in GitHub\u2026';
                panel.appendChild(title);
                ITEMS.forEach(({ label, icon, suffix }) => {
                    const row = document.createElement('div');
                    row.className = 'gm-gh-dropdown-item';
                    row.dataset.suffix = suffix;
                    row.innerHTML = `<i class="bi ${icon}" aria-hidden="true"></i><span>${label}</span>`;
                    panel.appendChild(row);
                });
                panel.addEventListener('mouseenter', cancelHide);
                panel.addEventListener('mouseleave', scheduleHide);
                panel.addEventListener('click', onItemClick);
                document.body.appendChild(panel);
            }

            function show(trigger) {
                if (!panel) build();
                cancelHide();
                activeTrigger = trigger;
                const r = trigger.getBoundingClientRect();
                panel.style.top  = (r.bottom + 4) + 'px';
                panel.style.right = (window.innerWidth - r.right) + 'px';
                panel.style.left = 'auto';
                panel.classList.add('gm-gh-dropdown--visible');
            }

            function hide() {
                panel?.classList.remove('gm-gh-dropdown--visible');
                activeTrigger = null;
            }

            function scheduleHide() { hideTimer = setTimeout(hide, 150); }
            function cancelHide()   { clearTimeout(hideTimer); }

            function openUrls(urls) {
                urls.filter(u => u).forEach(u => window.open(u, '_blank', 'noopener,noreferrer'));
            }

            function appendSuffix(url, suffix) {
                const base = (url || '').replace(/\/+$/, '');
                return base ? (base + suffix) : '';
            }

            // Clicking the trigger itself opens all repos directly (no suffix).
            document.addEventListener('click', e => {
                const wrap = e.target.closest('.github-dropdown-wrap');
                if (!wrap) return;
                try {
                    const urls = JSON.parse(wrap.dataset.urls || '[]');
                    openUrls(urls);
                } catch (_) { }
                hide();
            });

            function onItemClick(e) {
                const item = e.target.closest('.gm-gh-dropdown-item');
                if (!item || !activeTrigger) return;
                const suffix = item.dataset.suffix;
                try {
                    const urls = JSON.parse(activeTrigger.dataset.urls || '[]')
                        .filter(u => u)
                        .map(u => appendSuffix(u, suffix));
                    if (urls.length) urls.forEach(u => window.open(u, '_blank', 'noopener,noreferrer'));
                } catch (_) { }
                hide();
            }

            document.addEventListener('mouseover', e => {
                const wrap = e.target.closest('.github-dropdown-wrap');
                if (wrap) { show(wrap); return; }
                if (panel && panel.contains(e.target)) cancelHide();
            });

            document.addEventListener('mouseout', e => {
                const inWrap  = !!e.target.closest('.github-dropdown-wrap');
                const inPanel = !!(panel && panel.contains(e.target));
                if (!inWrap && !inPanel) return;
                const to = e.relatedTarget;
                if (!to) { scheduleHide(); return; }
                if (to.closest('.github-dropdown-wrap') || (panel && panel.contains(to))) return;
                scheduleHide();
            });
        })();

        window.graymoonStorageGet = (key) => localStorage.getItem(key);
        window.graymoonStorageSet = (key, value) => { localStorage.setItem(key, value); };
        document.body.addEventListener('click', (e) => {
            const el = e.target.closest('.dependency-level-count-link') || e.target.closest('.dependency-level-pr-link');
            if (!el) return;
            const raw = el.getAttribute('data-open-urls');
            if (!raw) return;
            e.preventDefault();
            e.stopPropagation();
            try {
                const urls = JSON.parse(raw);
                if (Array.isArray(urls) && urls.length > 0)
                    urls.forEach(url => window.open(url, '_blank', 'noopener,noreferrer'));
            } catch (_) { /* ignore */ }
        }, true);
    </script>
</body>

</html>
