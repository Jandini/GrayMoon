@using GrayMoon.App.Models
@using Microsoft.AspNetCore.Components.Web

@* PR column badge: none (dark gray), create (yellow, black text), #number (green), merged (purple), closed (red). Default "none" until data loads. *@
@if (IsOnTag)
{
    <span>&nbsp;</span>
}
else if (PullRequest != null && PullRequest.IsMerged)
{
    <a href="@PullRequest.HtmlUrl"
       target="_blank"
       rel="noopener noreferrer"
       class="badge pr-badge pr-badge-merged"
       title="PR #@PullRequest.Number merged">merged</a>
    @if (PullRequest.ChangedFiles is > 0)
    {
        <a href="@($"{PullRequest.HtmlUrl}/changes")"
           target="_blank"
           rel="noopener noreferrer"
           class="badge pr-badge pr-badge-merged pr-badge-files-changed"
           title="@($"{PullRequest.ChangedFiles} file{(PullRequest.ChangedFiles == 1 ? "" : "s")} changed")">
            @PullRequest.ChangedFiles
        </a>
    }
}
else if (PullRequest != null && PullRequest.IsClosed)
{
    <a href="@PullRequest.HtmlUrl"
       target="_blank"
       rel="noopener noreferrer"
       class="badge pr-badge pr-badge-closed"
       title="PR #@PullRequest.Number closed">closed</a>
    @if (PullRequest.ChangedFiles is > 0)
    {
        <a href="@($"{PullRequest.HtmlUrl}/changes")"
           target="_blank"
           rel="noopener noreferrer"
           class="badge pr-badge pr-badge-closed pr-badge-files-changed"
           title="@($"{PullRequest.ChangedFiles} file{(PullRequest.ChangedFiles == 1 ? "" : "s")} changed")">
            @PullRequest.ChangedFiles
        </a>
    }
}
else if (PullRequest != null && string.Equals(PullRequest.State, "open", StringComparison.OrdinalIgnoreCase))
{
    var openClass = GetOpenPrMergeabilityClass(PullRequest);
    var openTitle = GetOpenPrMergeabilityTitle(PullRequest);
    <a href="@PullRequest.HtmlUrl"
       target="_blank"
       rel="noopener noreferrer"
       class="badge pr-badge pr-badge-open @openClass"
       title="@openTitle">#@PullRequest.Number</a>
    @if (PullRequest.ChangedFiles is > 0)
    {
        <a href="@($"{PullRequest.HtmlUrl}/changes")"
           target="_blank"
           rel="noopener noreferrer"
           class="badge pr-badge pr-badge-open @openClass pr-badge-files-changed"
           title="@($"{PullRequest.ChangedFiles} file{(PullRequest.ChangedFiles == 1 ? "" : "s")} changed")">
            @PullRequest.ChangedFiles
        </a>
    }
}
else if (IsPrVerified && (PullRequest == null || !string.Equals(PullRequest.State, "open", StringComparison.OrdinalIgnoreCase)) && (DefaultBranchAheadCommits ?? 0) > 0)
{
    <span class="badge pr-badge pr-badge-create"
          role="button"
          tabindex="0"
          title="Create pull request"
          style="cursor: pointer;"
          @onclick="HandleCreateClick"
          @onclick:preventDefault
          @onclick:stopPropagation>create</span>
}
else
{
    <span class="badge pr-badge pr-badge-none" title="No pull request">none</span>
}

@code {
    [Parameter] public PullRequestInfo? PullRequest { get; set; }
    [Parameter] public int? DefaultBranchAheadCommits { get; set; }
    /// <summary>Deprecated. The create badge now invokes <see cref="OnCreateClick"/> instead of navigating to a URL.</summary>
    [Parameter] public string? CreatePrUrl { get; set; }
    /// <summary>Raised when the user clicks the yellow "create" badge.</summary>
    [Parameter] public EventCallback OnCreateClick { get; set; }
    /// <summary>When false, never show "create"; show "none" until PR state has been verified via API.</summary>
    [Parameter] public bool IsPrVerified { get; set; }
    /// <summary>True when the repository is checked out at a tag (detached HEAD); PRs require a branch, so render blank.</summary>
    [Parameter] public bool IsOnTag { get; set; }

    private async Task HandleCreateClick()
    {
        if (OnCreateClick.HasDelegate)
            await OnCreateClick.InvokeAsync();
    }

    private static string GetOpenPrMergeabilityClass(PullRequestInfo pr)
    {
        var state = pr.MergeableState ?? string.Empty;
        if (pr.Mergeable == null || string.Equals(state, "unknown", StringComparison.OrdinalIgnoreCase))
            return "pr-badge-open-unknown";
        if (pr.Mergeable == false || string.Equals(state, "dirty", StringComparison.OrdinalIgnoreCase))
            return "pr-badge-open-conflict";
        if (string.Equals(state, "unstable", StringComparison.OrdinalIgnoreCase))
            return "pr-badge-open-checks";
        if (string.Equals(state, "blocked", StringComparison.OrdinalIgnoreCase))
            return "pr-badge-open-blocked";
        if (pr.Mergeable == true || string.Equals(state, "clean", StringComparison.OrdinalIgnoreCase))
            return "pr-badge-open-mergeable";
        return "pr-badge-open-unknown";
    }

    private static string GetOpenPrMergeabilityTitle(PullRequestInfo pr)
    {
        var state = pr.MergeableState ?? string.Empty;
        if (pr.Mergeable == null || string.Equals(state, "unknown", StringComparison.OrdinalIgnoreCase))
            return "PR #" + pr.Number + " - mergeability unknown";
        if (pr.Mergeable == false || string.Equals(state, "dirty", StringComparison.OrdinalIgnoreCase))
            return "PR #" + pr.Number + " - merge conflicts";
        if (string.Equals(state, "unstable", StringComparison.OrdinalIgnoreCase))
            return "PR #" + pr.Number + " - checks running";
        if (string.Equals(state, "blocked", StringComparison.OrdinalIgnoreCase))
            return "PR #" + pr.Number + " - Cannot merge (review or requirements)";
        if (pr.Mergeable == true || string.Equals(state, "clean", StringComparison.OrdinalIgnoreCase))
            return "PR #" + pr.Number + " - mergeable";
        return "PR #" + pr.Number;
    }
}
