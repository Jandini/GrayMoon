@using GrayMoon.Common.Search
@inject IJSRuntime Js

<div class="filter-search-wrap @GetSearchWrapClass() @WrapperAdditionalClass">
    @if (ShowSearchHighlight)
    {
        <div class="filter-search-backdrop"
             @ref="_searchBackdrop"
             aria-hidden="true">
            <div class="filter-search-backdrop-inner">
                @foreach (var segment in FilterSearchExpression.GetHighlightSegments(Value))
                {
                    <span class="@GetHighlightClass(segment.Kind)">@segment.Text</span>
                }
            </div>
        </div>
    }
    <input id="@InputId"
           class="form-control filter-search-input @GetSearchInputClass() @InputAdditionalClass"
           placeholder="@Placeholder"
           value="@Value"
           disabled="@Disabled"
           autocomplete="off"
           @oninput="OnInputAsync"
           @onscroll="OnSearchScrollAsync"
           @onkeydown="OnKeyDown"
           @ref="_inputElement" />
    @if (!string.IsNullOrEmpty(Value))
    {
        <button type="button"
                class="filter-search-clear"
                title="Clear filter"
                aria-label="@ClearAriaLabel"
                disabled="@Disabled"
                @onclick="ClearAsync"
                @onclick:stopPropagation="true">
            <i class="bi bi-x-circle" aria-hidden="true"></i>
        </button>
    }
</div>

@code {
    private ElementReference _inputElement;
    private ElementReference _searchBackdrop;

    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Search…";
    [Parameter] public string? InputId { get; set; }
    [Parameter] public string InputAdditionalClass { get; set; } = string.Empty;
    [Parameter] public string WrapperAdditionalClass { get; set; } = string.Empty;
    [Parameter] public string ClearAriaLabel { get; set; } = "Clear search filter";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool EnableSyntaxHighlight { get; set; } = true;
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }
    [Parameter] public EventCallback OnClear { get; set; }

    private bool IsSearchSyntaxValid => FilterSearchExpression.IsValidQuery(Value);

    private bool ShowSearchHighlight =>
        EnableSyntaxHighlight && !string.IsNullOrEmpty(Value) && IsSearchSyntaxValid && !Disabled;

    public ValueTask FocusAsync() => _inputElement.FocusAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (ShowSearchHighlight)
        {
            await OnSearchScrollAsync();
        }
    }

    private string GetSearchWrapClass()
    {
        var classes = new List<string>();
        if (!string.IsNullOrEmpty(Value))
        {
            classes.Add("has-filter");
        }

        if (!IsSearchSyntaxValid)
        {
            classes.Add("filter-search-invalid");
        }

        return string.Join(' ', classes);
    }

    private string GetSearchInputClass() =>
        ShowSearchHighlight ? "filter-search-input-overlay" : IsSearchSyntaxValid ? string.Empty : "filter-search-input-invalid";

    private async Task OnInputAsync(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    private async Task ClearAsync()
    {
        Value = string.Empty;
        await ValueChanged.InvokeAsync(Value);
        if (OnClear.HasDelegate)
        {
            await OnClear.InvokeAsync();
        }
    }

    private async Task OnSearchScrollAsync()
    {
        if (!ShowSearchHighlight)
        {
            return;
        }

        try
        {
            await Js.InvokeVoidAsync("grayMoonFilterSearch.syncScroll", _inputElement, _searchBackdrop);
        }
        catch (JSException)
        {
            // Backdrop not mounted yet during prerender.
        }
    }

    private static string GetHighlightClass(FilterSearchHighlightKind kind) => kind switch
    {
        FilterSearchHighlightKind.OperatorAnd => "filter-search-token-and",
        FilterSearchHighlightKind.OperatorOr => "filter-search-token-or",
        FilterSearchHighlightKind.Paren => "filter-search-token-paren",
        FilterSearchHighlightKind.FieldPrefix => "filter-search-token-field",
        FilterSearchHighlightKind.FieldValue => "filter-search-token-field-value",
        FilterSearchHighlightKind.Whitespace => "filter-search-token-ws",
        _ => "filter-search-token-text",
    };
}
