@using GrayMoon.App.Services
@using GrayMoon.App.Models
@inject GhaWorkflowLiveFeedService GhaWorkflowLiveFeedService
@inject LoadingOverlayUiSettingsService OverlayUiSettings
@implements IAsyncDisposable

@if (RunId > 0 && !string.IsNullOrWhiteSpace(ConnectorName) && !string.IsNullOrWhiteSpace(Owner) && !string.IsNullOrWhiteSpace(RepositoryName))
{
    var schemeClass = OverlayUiSettings.TerminalColorScheme == TerminalColorScheme.Yellow
        ? "loading-overlay-terminal--scheme-yellow"
        : "";
    <div class="actions-gha-terminal">
        <div class="actions-gha-terminal__wrap">
            <div class="loading-overlay-terminal @schemeClass actions-gha-terminal__terminal">
                <div class="actions-gha-terminal__caption" title="@_boardCaption">
                    <span class="actions-gha-terminal__caption-main">
                        <span class="actions-gha-terminal__caption-prefix">▶</span><span class="actions-gha-terminal__caption-text">@_boardCaption</span>
                    </span>
                    @if (!string.IsNullOrWhiteSpace(_stepProgress))
                    {
                        <span class="actions-gha-terminal__caption-steps">@_stepProgress</span>
                    }
                </div>
                <div class="loading-overlay-terminal__inner actions-gha-terminal__scroll" aria-live="polite">
                    @for (var i = 0; i < BodyLineCount; i++)
                    {
                        var line = i == _spinnerBoardIdx
                            ? _boardSlots[i] + _spinnerText
                            : _boardSlots[i];
                        var timing = _timingSlots[i];
                        <p class="loading-overlay-terminal__line loading-overlay-terminal__line--out actions-gha-terminal__line">
                            @if (string.IsNullOrWhiteSpace(line))
                            {
                                <span class="loading-overlay-terminal__text">&nbsp;</span>
                            }
                            else
                            {
                                <span class="loading-overlay-terminal__prefix">[step]</span>
                                <span class="loading-overlay-terminal__text actions-gha-terminal__step-text">@line</span>
                                @if (!string.IsNullOrWhiteSpace(timing))
                                {
                                    <span class="actions-gha-terminal__step-timing@(i == _spinnerBoardIdx ? " actions-gha-terminal__step-timing--active" : "")">@timing</span>
                                }
                            }
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string ConnectorName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Owner { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string RepositoryName { get; set; } = string.Empty;
    [Parameter] public long RunId { get; set; }
    [Parameter] public string? WorkflowDisplayName { get; set; }

    private readonly string[] _boardSlots  = new string[BodyLineCount];
    private readonly string[] _timingSlots = new string[BodyLineCount];
    private string _boardCaption = "Steps · Waiting…";
    private string? _stepProgress;

    // Spinner — runs on its own 200ms loop, independent of the API poll
    private static readonly char[] SpinnerFrames = ['⠋', '⠙', '⠸', '⠴', '⠦', '⠧'];
    private int _spinnerFrame;
    private string? _spinnerStepKey;
    private int _spinnerBoardIdx = -1;  // board slot index of current in-progress step (-1 = none)
    private string _spinnerText = "";   // "  ...⠙" suffix appended to the in-progress slot

    private GhaWorkflowLiveFeedState? _feedState;
    private CancellationTokenSource? _cts;
    private Task? _pollTask;
    private Task? _spinnerTask;

    private const int BodyLineCount = 8;
    private const int SpinnerFrameMs = 200; // 6 frames × 200ms = 1.2s per revolution

    protected override void OnInitialized()
    {
        OverlayUiSettings.Changed += OnOverlayUiSettingsChanged;
    }

    private void OnOverlayUiSettingsChanged(object? sender, EventArgs e) =>
        _ = InvokeAsync(StateHasChanged);

    protected override Task OnParametersSetAsync()
    {
        if (RunId > 0 && _pollTask == null)
        {
            _feedState = new GhaWorkflowLiveFeedState
            {
                ConnectorName = ConnectorName,
                Owner = Owner,
                RepositoryName = RepositoryName,
                RunId = RunId,
                WorkflowDisplayName = WorkflowDisplayName
            };
            _cts = new CancellationTokenSource();
            _pollTask    = PollLoopAsync(_cts.Token);
            _spinnerTask = SpinnerLoopAsync(_cts.Token);
        }

        return Task.CompletedTask;
    }

    private async Task PollLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                var delayMs = await PollOnceAsync(cancellationToken);
                await Task.Delay(delayMs, cancellationToken);
            }
        }
        catch (OperationCanceledException) { /* disposed */ }
    }

    private async Task SpinnerLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(SpinnerFrameMs, cancellationToken);
                await InvokeAsync(() =>
                {
                    if (_spinnerBoardIdx < 0)
                        return;

                    _spinnerFrame = (_spinnerFrame + 1) % SpinnerFrames.Length;
                    _spinnerText = $"  {SpinnerFrames[_spinnerFrame]}";
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) { /* disposed */ }
    }

    private async Task<int> PollOnceAsync(CancellationToken cancellationToken)
    {
        if (_feedState == null)
            return GhaWorkflowLiveFeedService.PollIntervalWaitingJobsMs;

        var update = await GhaWorkflowLiveFeedService.PollOnceAsync(_feedState, cancellationToken);

        // All state mutations run on the Blazor circuit thread to stay consistent with the spinner loop
        await InvokeAsync(() =>
        {
            if (!string.Equals(_boardCaption, update.Caption, StringComparison.Ordinal)
                || !string.Equals(_stepProgress, update.StepProgress, StringComparison.Ordinal))
            {
                _boardCaption = update.Caption;
                _stepProgress = update.StepProgress;
            }
            UpdateBoard();
            StateHasChanged();
        });

        return update.DelayMs;
    }

    private static string FormatDuration(DateTimeOffset? start, DateTimeOffset? end)
    {
        if (start == null || end == null) return "";
        var elapsed = end.Value - start.Value;
        if (elapsed < TimeSpan.Zero) return "";
        if (elapsed.TotalSeconds < 60)
            return elapsed.TotalSeconds < 10
                ? $"{elapsed.TotalSeconds:F1}s"
                : $"{(int)elapsed.TotalSeconds}s";
        return $"{(int)elapsed.TotalMinutes}m {elapsed.Seconds}s";
    }

    private void UpdateBoard()
    {
        var job = _feedState?.ActiveJob;
        var steps = job?.Steps;

        if (job == null || steps == null || steps.Count == 0)
        {
            for (var i = 0; i < BodyLineCount; i++) { _boardSlots[i] = ""; _timingSlots[i] = ""; }
            _spinnerBoardIdx = -1;
            return;
        }

        var activeIdx = steps.FindIndex(s =>
            string.Equals(s.Status, "in_progress", StringComparison.OrdinalIgnoreCase));
        if (activeIdx < 0)
            activeIdx = steps.FindLastIndex(s =>
                string.Equals(s.Status, "completed", StringComparison.OrdinalIgnoreCase));

        var startIdx = 0;
        if (steps.Count > BodyLineCount && activeIdx >= 0)
            startIdx = Math.Max(0, Math.Min(activeIdx - BodyLineCount / 2 + 1, steps.Count - BodyLineCount));

        var newSpinnerIdx = -1;

        for (var i = 0; i < BodyLineCount; i++)
        {
            var si = startIdx + i;
            if (si >= steps.Count)
            {
                _boardSlots[i]  = "";
                _timingSlots[i] = "";
                continue;
            }

            var step = steps[si];
            var isInProgress = step.Status.Equals("in_progress", StringComparison.OrdinalIgnoreCase);
            var isCompleted  = step.Status.Equals("completed",   StringComparison.OrdinalIgnoreCase);

            _timingSlots[i] = isCompleted
                ? FormatDuration(step.StartedAt, step.CompletedAt)
                : isInProgress
                    ? FormatDuration(step.StartedAt, DateTimeOffset.UtcNow)
                    : "";

            if (isInProgress)
            {
                var stepKey = $"{job.Id}:{step.Number}";
                if (!string.Equals(_spinnerStepKey, stepKey, StringComparison.Ordinal))
                {
                    // New step started — reset spinner
                    _spinnerStepKey = stepKey;
                    _spinnerFrame   = 0;
                    _spinnerText    = "";
                }
                newSpinnerIdx  = i;
                _boardSlots[i] = $"▶ {step.Name}";
            }
            else
            {
                _boardSlots[i] = $"{StepIcon(step)} {step.Name}";
            }
        }

        _spinnerBoardIdx = newSpinnerIdx;
    }

    private static string StepIcon(GitHubWorkflowJobStepDto step)
    {
        if (string.Equals(step.Status, "in_progress", StringComparison.OrdinalIgnoreCase))
            return "▶";
        if (string.Equals(step.Status, "completed", StringComparison.OrdinalIgnoreCase))
        {
            return (step.Conclusion ?? "").ToLowerInvariant() switch
            {
                "success"                => "✓",
                "failure" or "cancelled" => "✗",
                "skipped"                => "↩",
                _                        => "·"
            };
        }
        return "○";
    }

    public async ValueTask DisposeAsync()
    {
        OverlayUiSettings.Changed -= OnOverlayUiSettingsChanged;
        try
        {
            _cts?.Cancel();
            var tasks = new List<Task?> { _pollTask, _spinnerTask };
            await Task.WhenAll(tasks.Where(t => t != null)!);
        }
        catch (OperationCanceledException) { /* ok */ }
        finally
        {
            _cts?.Dispose();
            _cts = null;
        }
    }
}
