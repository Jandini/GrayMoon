@using GrayMoon.App.Services
@using GrayMoon.App.Models
@inject GhaWorkflowLiveFeedService GhaWorkflowLiveFeedService
@inject GhaStepLogFeedService GhaStepLogFeedService
@inject LoadingOverlayUiSettingsService OverlayUiSettings
@implements IAsyncDisposable

@if (RunId > 0 && !string.IsNullOrWhiteSpace(ConnectorName) && !string.IsNullOrWhiteSpace(Owner) && !string.IsNullOrWhiteSpace(RepositoryName))
{
    var schemeClass = OverlayUiSettings.TerminalColorScheme == TerminalColorScheme.Yellow
        ? "loading-overlay-terminal--scheme-yellow"
        : "";
    <div class="actions-gha-terminal">
        <div class="actions-gha-terminal__wrap actions-gha-terminal__wrap--split">

            <!-- LEFT: step-status board -->
            <div class="loading-overlay-terminal @schemeClass actions-gha-terminal__terminal actions-gha-terminal__pane actions-gha-terminal__pane--left">
                <div class="actions-gha-terminal__caption" title="@_captionTooltip">
                    <span class="actions-gha-terminal__caption-main">
                        <span class="actions-gha-terminal__caption-prefix">▶</span><span class="actions-gha-terminal__caption-text">@_caption</span>
                    </span>
                    @if (!string.IsNullOrWhiteSpace(_stepProgress))
                    {
                        <span class="actions-gha-terminal__caption-steps">@_stepProgress</span>
                    }
                </div>
                <div class="loading-overlay-terminal__inner actions-gha-terminal__scroll" aria-live="polite">
                    @for (var i = 0; i < BodyLineCount; i++)
                    {
                        var line = _boardSlots[i];
                        <p class="loading-overlay-terminal__line loading-overlay-terminal__line--out actions-gha-terminal__line">
                            @if (string.IsNullOrWhiteSpace(line))
                            {
                                <span class="loading-overlay-terminal__text">&nbsp;</span>
                            }
                            else
                            {
                                <span class="loading-overlay-terminal__prefix">[job]</span><span class="loading-overlay-terminal__text">@line</span>
                            }
                        </p>
                    }
                </div>
            </div>

            <!-- RIGHT: step execution log (neutral white/gray palette) -->
            <div class="loading-overlay-terminal actions-gha-terminal__terminal actions-gha-terminal__pane actions-gha-terminal__pane--right actions-gha-terminal__pane--log">
                <div class="actions-gha-terminal__caption" title="@_logCaption">
                    <span class="actions-gha-terminal__caption-main">
                        <span class="actions-gha-terminal__caption-prefix">▶</span><span class="actions-gha-terminal__caption-text">@_logCaption</span>
                    </span>
                </div>
                <div class="loading-overlay-terminal__inner actions-gha-terminal__scroll" aria-live="polite">
                    @for (var i = 0; i < BodyLineCount; i++)
                    {
                        var line = _logSlots[i];
                        <p class="loading-overlay-terminal__line loading-overlay-terminal__line--out actions-gha-terminal__line">
                            @if (string.IsNullOrWhiteSpace(line))
                            {
                                <span class="loading-overlay-terminal__text">&nbsp;</span>
                            }
                            else
                            {
                                <span class="loading-overlay-terminal__prefix">[log]</span><span class="loading-overlay-terminal__text">@line</span>
                            }
                        </p>
                    }
                </div>
            </div>

        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string ConnectorName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Owner { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string RepositoryName { get; set; } = string.Empty;
    [Parameter] public long RunId { get; set; }
    [Parameter] public string? WorkflowDisplayName { get; set; }

    // Left panel: step-status board — computed each poll from feed state, no buffer needed
    private readonly string[] _boardSlots = new string[BodyLineCount];
    private string _caption = "Workflow · Connecting to GitHub Actions…";
    private string? _stepProgress;

    // Right panel: step execution logs — circular buffer fed by GhaStepLogFeedService
    private readonly List<string> _logBuffer = [];
    private readonly string[] _logSlots = new string[BodyLineCount];
    private readonly GhaStepLogFeedState _logFeedState = new();
    private string _logCaption = "Step log · Waiting…";
    private long _lastLogPollTick;
    private const int LogPollIntervalMs = 3_000;

    private GhaWorkflowLiveFeedState? _feedState;
    private CancellationTokenSource? _cts;
    private Task? _pollTask;
    private bool _needsRender;

    private const int BodyLineCount = 8;
    private string _captionTooltip =>
        string.IsNullOrWhiteSpace(_stepProgress) ? _caption : $"{_caption} · {_stepProgress}";

    protected override void OnInitialized()
    {
        OverlayUiSettings.Changed += OnOverlayUiSettingsChanged;
    }

    private void OnOverlayUiSettingsChanged(object? sender, EventArgs e) =>
        _ = InvokeAsync(StateHasChanged);

    protected override Task OnParametersSetAsync()
    {
        if (RunId > 0 && _pollTask == null)
        {
            _feedState = new GhaWorkflowLiveFeedState
            {
                ConnectorName = ConnectorName,
                Owner = Owner,
                RepositoryName = RepositoryName,
                RunId = RunId,
                WorkflowDisplayName = WorkflowDisplayName
            };
            _cts = new CancellationTokenSource();
            _pollTask = PollLoopAsync(_cts.Token);
        }

        return Task.CompletedTask;
    }

    private async Task PollLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                var delayMs = await PollOnceAsync(cancellationToken);
                if (_needsRender)
                {
                    _needsRender = false;
                    await InvokeAsync(StateHasChanged);
                }
                await Task.Delay(delayMs, cancellationToken);
            }
        }
        catch (OperationCanceledException) { /* disposed */ }
    }

    private async Task<int> PollOnceAsync(CancellationToken cancellationToken)
    {
        if (_feedState == null)
            return GhaWorkflowLiveFeedService.PollIntervalWaitingJobsMs;

        var update = await GhaWorkflowLiveFeedService.PollOnceAsync(_feedState, cancellationToken);
        if (!string.Equals(_caption, update.Caption, StringComparison.Ordinal)
            || !string.Equals(_stepProgress, update.StepProgress, StringComparison.Ordinal))
        {
            _caption = update.Caption;
            _stepProgress = update.StepProgress;
            _needsRender = true;
        }

        // Left panel: rebuild step-status board from already-fetched job data
        UpdateBoard();

        // Right panel: poll step logs at a slower rate, only when a job is active
        var nowTick = Environment.TickCount64;
        if (nowTick - _lastLogPollTick >= LogPollIntervalMs && _feedState.CurrentInProgressJobId != null)
        {
            _lastLogPollTick = nowTick;
            await PollStepLogsAsync(cancellationToken);
        }

        return update.DelayMs;
    }

    private void UpdateBoard()
    {
        var job = _feedState?.ActiveJob;
        var steps = job?.Steps;

        if (job == null || steps == null || steps.Count == 0)
        {
            for (var i = 0; i < BodyLineCount; i++) _boardSlots[i] = "";
            _needsRender = true;
            return;
        }

        // Scroll window to keep the active (▶) step visible
        var activeIdx = steps.FindIndex(s =>
            string.Equals(s.Status, "in_progress", StringComparison.OrdinalIgnoreCase));
        if (activeIdx < 0)
            activeIdx = steps.FindLastIndex(s =>
                string.Equals(s.Status, "completed", StringComparison.OrdinalIgnoreCase));

        var startIdx = 0;
        if (steps.Count > BodyLineCount && activeIdx >= 0)
            startIdx = Math.Max(0, Math.Min(activeIdx - BodyLineCount / 2 + 1, steps.Count - BodyLineCount));

        for (var i = 0; i < BodyLineCount; i++)
        {
            var si = startIdx + i;
            _boardSlots[i] = si < steps.Count ? $"{StepIcon(steps[si])} {steps[si].Name}" : "";
        }

        _needsRender = true;
    }

    private async Task PollStepLogsAsync(CancellationToken cancellationToken)
    {
        if (_feedState == null) return;

        var logUpdate = await GhaStepLogFeedService.PollStepLogsAsync(_feedState, _logFeedState, cancellationToken);

        if (logUpdate.StepChanged)
        {
            _logBuffer.Clear();
            _logCaption = string.IsNullOrWhiteSpace(logUpdate.StepName)
                ? "Step log · Waiting…"
                : logUpdate.StepName;
            RefreshSlots(_logBuffer, _logSlots);
            _needsRender = true;
        }

        foreach (var line in logUpdate.NewLines)
            AppendLog(line);
    }

    private void AppendLog(string line)
    {
        if (_logBuffer.Count > 0 && string.Equals(_logBuffer[^1], line, StringComparison.Ordinal))
            return;
        _logBuffer.Add(line);
        while (_logBuffer.Count > 200)
            _logBuffer.RemoveAt(0);
        RefreshSlots(_logBuffer, _logSlots);
        _needsRender = true;
    }

    private static string StepIcon(GitHubWorkflowJobStepDto step)
    {
        if (string.Equals(step.Status, "in_progress", StringComparison.OrdinalIgnoreCase))
            return "▶";
        if (string.Equals(step.Status, "completed", StringComparison.OrdinalIgnoreCase))
        {
            return (step.Conclusion ?? "").ToLowerInvariant() switch
            {
                "success"                => "✓",
                "failure" or "cancelled" => "✗",
                "skipped"                => "↩",
                _                        => "·"
            };
        }
        return "○";
    }

    private static void RefreshSlots(List<string> buffer, string[] slots)
    {
        for (var i = 0; i < BodyLineCount; i++)
        {
            var idx = buffer.Count - BodyLineCount + i;
            slots[i] = idx >= 0 ? buffer[idx] : "";
        }
    }

    public async ValueTask DisposeAsync()
    {
        OverlayUiSettings.Changed -= OnOverlayUiSettingsChanged;
        try
        {
            _cts?.Cancel();
            if (_pollTask != null)
                await _pollTask;
        }
        catch (OperationCanceledException) { /* ok */ }
        finally
        {
            _cts?.Dispose();
            _cts = null;
        }
    }
}
