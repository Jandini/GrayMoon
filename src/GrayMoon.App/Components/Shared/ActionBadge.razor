@using GrayMoon.App.Models

@* CI action status badge: none (gray), success (green), running (orange), failed (red). Shows "none" until status is verified. *@
@if (string.Equals(Status, "success", StringComparison.OrdinalIgnoreCase))
{
    @if (!string.IsNullOrWhiteSpace(HtmlUrl))
    {
        <a href="@HtmlUrl" target="_blank" rel="noopener noreferrer"
           class="badge action-badge action-badge-success" title="All checks passed">success</a>
    }
    else
    {
        <span class="badge action-badge action-badge-success" title="All checks passed">success</span>
    }
}
else if (string.Equals(Status, "running", StringComparison.OrdinalIgnoreCase))
{
    @if (!string.IsNullOrWhiteSpace(HtmlUrl))
    {
        <a href="@HtmlUrl" target="_blank" rel="noopener noreferrer"
           class="badge action-badge action-badge-running" title="Checks in progress">running</a>
    }
    else
    {
        <span class="badge action-badge action-badge-running" title="Checks in progress">running</span>
    }
}
else if (string.Equals(Status, "failed", StringComparison.OrdinalIgnoreCase))
{
    @if (!string.IsNullOrWhiteSpace(HtmlUrl))
    {
        <a href="@HtmlUrl" target="_blank" rel="noopener noreferrer"
           class="badge action-badge action-badge-failed" title="Checks failed">failed</a>
    }
    else
    {
        <span class="badge action-badge action-badge-failed" title="Checks failed">failed</span>
    }
}
else
{
    <span class="badge action-badge action-badge-none" title="No action status">none</span>
}

@code {
    [Parameter] public string? Status { get; set; }
    [Parameter] public string? HtmlUrl { get; set; }
}
